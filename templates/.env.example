# GraphQL (when API client is GraphQL)
# Dev placeholder — Rick and Morty API (query-only); replace with your project endpoint
EXPO_PUBLIC_GRAPHQL_URL=https://rickandmortyapi.com/graphql

# Subscriptions (opt-in at intake — enables WS link when your schema has subscriptions)
# EXPO_PUBLIC_GRAPHQL_SUBSCRIPTIONS_ENABLED=true
# EXPO_PUBLIC_GRAPHQL_WS_URL=

# REST (when API client is REST — mutually exclusive with GraphQL)
# Dev placeholder — JSONPlaceholder; replace with your project base URL
# EXPO_PUBLIC_API_URL=https://jsonplaceholder.typicode.com
