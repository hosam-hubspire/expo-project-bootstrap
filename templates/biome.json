{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/.expo",
      "!**/android",
      "!**/ios",
      "!**/coverage",
      "!**/dist",
      "!**/web-build",
      "!**/src/theme/tokens/generated",
      "!**/src/services/graphql/generated",
      "!**/src/stories/design-tokens/token-definitions.ts",
      "!**/assets/icons",
      "!**/assets/expo.icon",
      "!**/.rnstorybook/storybook.requires.ts",
      "!**/.cursor/mcp.json",
      "!**/.mcp.json",
      "!**/.vscode/mcp.json",
      "!**/.claude/settings.json",
      "!**/.claude/agents",
      "!**/.agents"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "globals": ["__DEV__"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "test": "recommended"
    },
    "rules": {
      "preset": "recommended",
      "a11y": {
        "preset": "recommended"
      },
      "nursery": {
        "noReactNativeRawText": {
          "level": "error",
          "options": {
            "skip": ["ThemedText"]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
