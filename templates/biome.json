{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/.expo",
      "!**/android",
      "!**/ios",
      "!**/coverage",
      "!**/dist",
      "!**/web-build",
      "!**/src/theme/tokens/generated",
      "!**/src/services/graphql/generated",
      "!**/src/stories/design-tokens/token-definitions.ts",
      "!**/assets/icons",
      "!**/assets/expo.icon",
      "!**/.rnstorybook/storybook.requires.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "globals": ["__DEV__"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "test": "recommended"
    },
    "rules": {
      "preset": "recommended",
      "a11y": {
        "preset": "recommended"
      },
      "nursery": {
        "noReactNativeRawText": {
          "level": "error",
          "options": {
            "skip": ["ThemedText"]
          }
        }
      },
      "style": {
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "strictCase": true,
            "filenameCases": ["kebab-case", "export"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/components/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": {
                "strictCase": true,
                "filenameCases": ["PascalCase", "export"]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/app/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": {
                "strictCase": true,
                "filenameCases": ["kebab-case", "export"]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/components/**/index.ts"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": {
                "strictCase": true,
                "filenameCases": ["kebab-case"]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/stories/design-tokens/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": {
                "strictCase": true,
                "filenameCases": ["PascalCase", "export"]
              }
            }
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
